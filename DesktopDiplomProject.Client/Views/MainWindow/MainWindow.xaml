<Window x:Class="TestDiplomProject.Views.MainWindow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestDiplomProject.Views.MainWindow"
        mc:Ignorable="d" Closed="Window_Closed"
        Title="MainWindow" Height="768" Width="1366"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Border x:Name="HeaderBorder" BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="0 0 0 3" Margin="0 0 0 5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="1" Margin="0 0 50 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="UserButton" Style="{StaticResource SecondaryButtonStyle}" Width="32" Height="32" Padding="0" Click="UserButton_Click">
                        <Image x:Name="UserImage" Grid.Column="0" Source="{StaticResource User_Icon}" Stretch="Fill" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                    <Popup Grid.Column="0" IsOpen="{Binding IsUserMenuOpen}" PlacementTarget="{Binding ElementName=UserImage}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border BorderBrush="{StaticResource DividerBrush}" BorderThickness="1">
                            <StackPanel Orientation="Vertical" Background="{StaticResource SurfaceBrush}">
                                <MenuItem Header="Сменить пользователя">
                                    <MenuItem.Icon>
                                        <Image Source="{StaticResource Change_User_Icon}" Stretch="Fill" RenderOptions.BitmapScalingMode="Fant"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <TextBlock Grid.Column="1" Text="Пользователь Пользователев" Cursor="Hand" VerticalAlignment="Center" Margin="5">
                        <TextBlock.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Сменить пользователя" Click="MenuItem_Click" FontSize="{StaticResource FontSizeSmall}">
                                    <MenuItem.Icon>
                                        <Image Source="{StaticResource Change_User_Icon}" Stretch="Fill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </TextBlock.ContextMenu>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="5">
                <Button x:Name="SelectionButton" Content="Подбор" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                        Style="{StaticResource PrimaryButtonStyle}" Click="SelectionButton_Click"/>
                <GridSplitter Foreground="{StaticResource DividerBrush}" Height="3" HorizontalAlignment="Stretch" Margin="0 5"/>
                <Button x:Name="MyPCButton" Content="Мой ПК" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                        Style="{StaticResource PrimaryButtonStyle}" Click="MyPCButton_Click"/>
            </StackPanel>
            <GridSplitter Grid.Column="1" Margin="5" Width="3" Foreground="{StaticResource DividerBrush}"/>
            <Frame Grid.Column="2" x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"
                   JournalOwnership="OwnsJournal">
            </Frame>
        </Grid>
    </Grid>
</Window>
