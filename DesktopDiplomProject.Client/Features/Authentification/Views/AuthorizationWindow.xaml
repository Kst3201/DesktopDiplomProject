<Window x:Class="TestDiplomProject.Views.Authorization.AuthorizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestDiplomProject.Views.Authorization"
        mc:Ignorable="d"
        Title="Вход и регистрация" Height="800" Width="600" MinHeight="450" MinWidth="500"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="12*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="24*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource SurfaceBrush}" BorderThickness="0" CornerRadius="20"
                Margin="10" Padding="10" MaxWidth="600">
            <Frame x:Name="AuthFrame"
               NavigationUIVisibility="Hidden"
               JournalOwnership="OwnsJournal"
               >
            </Frame>
        </Border>
    </Grid>
</Window>
